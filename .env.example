# --- Production / Vercel (server env — never use VITE_ for the Anthropic key) ---
ANTHROPIC_API_KEY=

# Required on Vercel preview & production: https://upstash.com/ (free Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: cap searches per IP per minute (default 20, max 120)
# RATE_LIMIT_PER_MINUTE=20

# Optional: if the UI is served from a different origin than the API
# VITE_API_BASE_URL=https://your-deployment.vercel.app

# --- Local dev (choose one) ---
# Recommended: run `npx vercel dev` and put ANTHROPIC_API_KEY + Upstash vars in .env.local
# (Vercel CLI loads .env.local automatically.)

# Quick path for `npm run vite` only — key stays in YOUR browser; do NOT set on Vercel:
# VITE_ANTHROPIC_API_KEY=
